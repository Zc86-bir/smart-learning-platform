# ==========================================
# Smart Learn Platform - Environment Variables Template
# ==========================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# Database
DB_URL=jdbc:mysql://localhost:3306/smart_learning?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# JWT (生产环境请使用强随机密钥，可通过 openssl rand -base64 64 生成)
JWT_SECRET=
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# MiMo AI
MIMO_API_KEY=

# OAuth2 GitHub
OAUTH2_GITHUB_CLIENT_ID=
OAUTH2_GITHUB_CLIENT_SECRET=

# OAuth2 WeChat (optional)
OAUTH2_WECHAT_CLIENT_ID=
OAUTH2_WECHAT_CLIENT_SECRET=
